{
  "trait": "sys.openapi",
  "description": "Generate OpenAPI 3.0 specification from the trait registry",
  "features": [
    {
      "name": "Generates OpenAPI 3.0 spec",
      "description": "Returns a complete OpenAPI specification with all trait endpoints",
      "tests": [
    {
      "name": "openapi returns valid spec",
      "command": "traits call sys.openapi",
      "assertions": [
        { "type": "exit_code", "expected": 0 },
        { "type": "contains", "expected": "openapi" },
        { "type": "contains", "expected": "3.0.3" },
        { "type": "contains", "expected": "traits.build API" }
      ]
    },
    {
      "name": "openapi contains trait paths",
      "command": "traits call sys.openapi",
      "assertions": [
        { "type": "contains", "expected": "/traits/sys/checksum" },
        { "type": "contains", "expected": "/traits/sys/list" }
      ]
    },
    {
      "name": "openapi has servers",
      "command": "traits call sys.openapi",
      "assertions": [
        { "type": "contains", "expected": "polygrait-api.fly.dev" },
        { "type": "contains", "expected": "127.0.0.1:8090" }
      ]
    }
  ],
      "examples": [
        {
          "input": [],
          "output": {
            "contains": ["\"openapi\":\"3.0.3\"", "\"paths\""]
          }
        }
      ]
    }
  ]
}
