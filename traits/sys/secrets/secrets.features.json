{
  "trait": "sys.secrets",
  "description": "Encrypted secrets store — set, get, delete, list with AES-256 encryption at rest",
  "features": [
    {
      "name": "Set and verify secret",
      "description": "Store a secret and verify it exists",
      "tests": [
        {
          "name": "set a test secret",
          "type": "command",
          "command": "./target/release/traits call sys.secrets set test_secret_1 my_api_key_123 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"ok\": true" },
            { "type": "contains", "expected": "\"action\": \"set\"" },
            { "type": "contains", "expected": "\"id\": \"test_secret_1\"" }
          ]
        },
        {
          "name": "verify secret exists",
          "type": "command",
          "command": "./target/release/traits call sys.secrets get test_secret_1 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"exists\": true" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["set", "example_key", "sk_live_test"],
          "output": {
            "contains": ["\"ok\":true", "\"action\":\"set\""]
          }
        }
      ]
    },
    {
      "name": "List secrets",
      "description": "List all stored secret IDs (values never exposed)",
      "tests": [
        {
          "name": "list returns secret IDs",
          "type": "command",
          "command": "./target/release/traits call sys.secrets list 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"ok\": true" },
            { "type": "contains", "expected": "\"action\": \"list\"" },
            { "type": "contains", "expected": "secrets" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["list"],
          "output": {
            "contains": ["\"ok\":true", "\"action\":\"list\"", "\"count\":"]
          }
        }
      ]
    },
    {
      "name": "Get secret (existence check only)",
      "description": "Get confirms existence without returning the value",
      "tests": [
        {
          "name": "get nonexistent secret returns exists false",
          "type": "command",
          "command": "./target/release/traits call sys.secrets get nonexistent_secret_xyz 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"exists\": false" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["get", "nonexistent_key"],
          "output": {
            "contains": ["\"ok\":true", "\"exists\":false"]
          }
        }
      ]
    },
    {
      "name": "Delete secret",
      "description": "Remove a secret from the store",
      "tests": [
        {
          "name": "delete nonexistent returns deleted false",
          "type": "command",
          "command": "./target/release/traits call sys.secrets delete never_existed_abc 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"deleted\": false" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["delete", "nonexistent_key"],
          "output": {
            "contains": ["\"ok\":true", "\"deleted\":false"]
          }
        }
      ]
    },
    {
      "name": "Resolve secret context",
      "description": "Resolve allowed secrets into a context (returns available IDs only)",
      "tests": [
        {
          "name": "resolve with no secrets returns empty",
          "type": "command",
          "command": "./target/release/traits call sys.secrets resolve '' 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"ok\": true" },
            { "type": "contains", "expected": "\"action\": \"resolve\"" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["resolve", "stripe_key,db_pass"],
          "output": {
            "contains": ["\"ok\":true", "\"action\":\"resolve\""]
          }
        }
      ]
    },
    {
      "name": "Unknown action error",
      "description": "Returns error with valid action list for unknown actions",
      "tests": [
        {
          "name": "unknown action returns error",
          "type": "command",
          "command": "./target/release/traits call sys.secrets badaction 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "Unknown action: badaction" }
          ]
        }
      ],
      "examples": [
        {
          "input": ["badaction"],
          "output": {
            "contains": ["Unknown action: badaction"]
          }
        }
      ]
    },
    {
      "name": "Validation: empty id",
      "description": "Set/get/delete require a non-empty secret id",
      "tests": [
        {
          "name": "set without id returns error",
          "type": "command",
          "command": "./target/release/traits call sys.secrets set '' '' 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "secret id is required" }
          ]
        }
      ]
    },
    {
      "name": "Validation: invalid id characters",
      "description": "Secret IDs must be alphanumeric with underscores and dots only",
      "tests": [
        {
          "name": "set with special chars returns error",
          "type": "command",
          "command": "./target/release/traits call sys.secrets set 'bad/id' value 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "must be alphanumeric" }
          ]
        }
      ]
    },
    {
      "name": "Delete stored secret cleanup",
      "description": "Clean up test secrets from the set test",
      "tests": [
        {
          "name": "delete the test secret",
          "type": "command",
          "command": "./target/release/traits call sys.secrets delete test_secret_1 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "\"deleted\": true" }
          ]
        },
        {
          "name": "delete the example secret",
          "type": "command",
          "command": "./target/release/traits call sys.secrets delete example_key 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 }
          ]
        }
      ]
    }
  ]
}
