{
  "module": "traits/kernel/reload/reload.rs",
  "description": "Reload trait registry from disk",
  "features": [
    {
      "name": "Reload registry",
      "description": "Re-scans traits directory and reloads all definitions",
      "tests": [
        {
          "name": "reload returns ok with count",
          "type": "command",
          "command": "./target/release/traits call sys.reload 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "ok" },
            { "type": "contains", "expected": "count" }
          ]
        }
      ],
      "examples": [
        {
          "input": [],
          "output": {
            "contains": ["ok", "count"]
          }
        }
      ]
    }
  ]
}
