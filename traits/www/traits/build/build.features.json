{
  "trait": "www.traits.build",
  "description": "Landing page HTML for traits.build — loaded as cdylib plugin via TOML discovery",
  "features": [
    {
      "name": "Returns valid HTML landing page",
      "description": "Calling www.website with no args returns a full HTML page",
      "tests": [
        {
          "name": "returns HTML with doctype",
          "type": "command",
          "command": "./target/release/traits call www.traits.build 2>/dev/null",
          "checks": [
            {
              "type": "exit_code",
              "expected": 0
            },
            {
              "type": "contains",
              "expected": "<!DOCTYPE html>"
            }
          ]
        },
        {
          "name": "contains traits.build branding",
          "type": "command",
          "command": "./target/release/traits call www.traits.build 2>/dev/null",
          "checks": [
            {
              "type": "exit_code",
              "expected": 0
            },
            {
              "type": "contains",
              "expected": "traits.build"
            }
          ]
        },
        {
          "name": "contains feature cards",
          "type": "command",
          "command": "./target/release/traits call www.traits.build 2>/dev/null",
          "checks": [
            {
              "type": "exit_code",
              "expected": 0
            },
            {
              "type": "contains",
              "expected": "AI-Ready by default"
            },
            {
              "type": "contains",
              "expected": "Single binary"
            }
          ]
        },
        {
          "name": "contains browser-native section",
          "type": "command",
          "command": "./target/release/traits call www.traits.build 2>/dev/null",
          "checks": [
            {
              "type": "exit_code",
              "expected": 0
            },
            {
              "type": "contains",
              "expected": "Browser-Native"
            },
            {
              "type": "contains",
              "expected": "WASM kernel"
            },
            {
              "type": "contains",
              "expected": "3-tier dispatch"
            }
          ]
        }
      ],
      "examples": [
        {
          "input": [],
          "output": {
            "contains": ["<!DOCTYPE html>", "traits.build"]
          }
        }
      ]
    }
  ]
}
