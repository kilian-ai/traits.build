{
  "trait": "www.admin",
  "description": "Admin dashboard for traits.build deployment",
  "features": [
    {
      "name": "Returns admin dashboard HTML",
      "description": "Calling www.admin returns an HTML admin page (requires Basic Auth in production)",
      "tests": [
        {
          "name": "returns HTML with doctype",
          "type": "command",
          "command": "./target/release/traits call www.admin 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "<!DOCTYPE html>" }
          ]
        },
        {
          "name": "contains admin branding",
          "type": "command",
          "command": "./target/release/traits call www.admin 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "admin" }
          ]
        },
        {
          "name": "contains dispatch card",
          "type": "command",
          "command": "./target/release/traits call www.admin 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "dotRest" },
            { "type": "contains", "expected": "dotRelay" },
            { "type": "contains", "expected": "checkDispatch" }
          ]
        }
      ],
      "examples": [
        {
          "input": [],
          "output": {
            "contains": ["<!DOCTYPE html>", "admin"]
          }
        }
      ]
    }
  ]
}
