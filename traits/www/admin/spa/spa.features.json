{
  "trait": "www.admin.spa",
  "description": "SPA-only local admin workspace",
  "features": [
    {
      "name": "Returns SPA admin HTML",
      "description": "Calling www.admin.spa returns the browser-local admin workspace",
      "tests": [
        {
          "name": "returns html with dispatch card and settings page",
          "type": "command",
          "command": "./target/release/traits call www.admin.spa 2>/dev/null",
          "checks": [
            { "type": "exit_code", "expected": 0 },
            { "type": "contains", "expected": "<!DOCTYPE html>" },
            { "type": "contains", "expected": "traits.build - Settings" },
            { "type": "contains", "expected": "dispatchCard" },
            { "type": "contains", "expected": "dotWasm" },
            { "type": "contains", "expected": "dotHelper" },
            { "type": "contains", "expected": "dotRelay" }
          ]
        }
      ]
    }
  ]
}