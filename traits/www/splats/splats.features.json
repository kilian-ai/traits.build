{
  "trait": "www.splats",
  "features": [
    {
      "name": "Render WebGPU splat viewer with default scene",
      "examples": [
        {
          "input": ["render"],
          "output": { "contains": ["splat-canvas", "WebGPU", "webgpu", "fetchSplat"] }
        },
        {
          "input": [],
          "output": { "contains": ["splat-canvas", "webgpu", "bonsai"] }
        }
      ]
    },
    {
      "name": "Render with custom URL",
      "examples": [
        {
          "input": ["render", "https://example.com/test.splat"],
          "output": { "contains": ["splat-canvas", "example.com/test.splat"] }
        }
      ]
    },
    {
      "name": "Return gallery of example scenes",
      "examples": [
        {
          "input": ["gallery"],
          "output": { "contains": ["ok", "scenes", "bonsai", "train"] }
        }
      ]
    }
  ]
}
